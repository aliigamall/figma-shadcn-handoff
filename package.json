{
  "name": "figma-handoff",
  "version": "0.1.0",
  "description": "Figma-to-code handoff toolchain: token export CLI + inspect-to-JSX via Figma MCP",
  "type": "module",
  "scripts": {
    "export-tokens": "tsx src/tokens/cli.ts",
    "debug:api": "tsx scripts/debug-api.ts",
    "debug:resolve": "tsx scripts/debug-resolve.ts",
    "debug:transform": "tsx scripts/debug-transform.ts",
    "debug:generate": "tsx scripts/debug-generate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
